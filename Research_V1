   "source": [
    "vol_momentum_windows = [60, 120, 180]\n",
    "volatility_windows = [20, 60]\n",
    "score_thresholds = [0.25, 0.50, 0.75]\n",
    "\n",
    "vol_adjusted_results = []\n",
    "\n",
    "for ticker in stock_tickers:\n",
    "    for momentum_window in vol_momentum_windows:\n",
    "        for volatility_window in volatility_windows:\n",
    "            for score_threshold in score_thresholds:\n",
    "                signal_frame = module.volatility_adjusted_momentum_signal(\n",
    "                    df_prices_in_sample[ticker],\n",
    "                    momentum_window=momentum_window,\n",
    "                    volatility_window=volatility_window,\n",
    "                    score_threshold=score_threshold,\n",
    "                )\n",
    "\n",
    "                statistics, portfolio_value = evaluate_single_signal(\n",
    "                    price_series=df_prices_in_sample[ticker],\n",
    "                    signal_frame=signal_frame,\n",
    "                    label=f'{ticker} VolAdjMom {momentum_window}/{volatility_window}/{score_threshold}',\n",
    "                )\n",
    "\n",
    "                statistics['Ticker'] = ticker\n",
    "                statistics['Signal'] = 'Volatility-Adjusted Momentum'\n",
    "                statistics['Momentum Window'] = momentum_window\n",
    "                statistics['Volatility Window'] = volatility_window\n",
    "                statistics['Score Threshold'] = score_threshold\n",
    "\n",
    "                vol_adjusted_results.append(statistics)\n",
    "\n",
    "df_vol_adjusted_results = pd.DataFrame(vol_adjusted_results)\n",
    "\n",
    "df_vol_adjusted_results = df_vol_adjusted_results.sort_values(\n",
    "    by=['Sharpe Ratio', 'Total Return'],\n",
    "    ascending=False,\n",
    ")\n",
    "\n",
    "format_statistics_table(df_vol_adjusted_results).head(15)"
   ]
