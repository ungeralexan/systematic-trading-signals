    "def evaluate_single_signal(price_series, signal_frame, label):\n",
    "    \"\"\"\n",
    "    Backtest one signal on one price series and compute performance statistics.\n",
    "    \"\"\"\n",
    "    portfolio_value = module.single_asset_backtest(\n",
    "        series=price_series,\n",
    "        signal_frame=signal_frame,\n",
    "        capital_fraction=1.0,\n",
    "        initial_cash=1.0,\n",
    "    )\n",
    "\n",
    "    statistics = module.compute_performance_statistics(\n",
    "        label=label,\n",
    "        portfolio_value=portfolio_value,\n",
    "    )\n",
    "\n",
    "    return statistics, portfolio_value\n",
    "\n",
    "\n",
    "def evaluate_buy_and_hold(price_series, label):\n",
    "    \"\"\"\n",
    "    Compute a buy-and-hold benchmark for one price series.\n",
    "    \"\"\"\n",
    "    prices = price_series.to_numpy(dtype=float)\n",
    "    portfolio_value = prices / prices[0]\n",
    "\n",
    "    statistics = module.compute_performance_statistics(\n",
    "        label=label,\n",
    "        portfolio_value=portfolio_value,\n",
    "    )\n",
    "\n",
    "    return statistics, portfolio_value\n",
    "\n",
    "\n",
    "def format_statistics_table(df):\n",
    "    \"\"\"\n",
    "    Format performance statistics for easier reading in the notebook.\n",
    "    \"\"\"\n",
    "    formatted = df.copy()\n",
    "\n",
